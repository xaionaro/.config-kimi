#!/usr/bin/env bash
set -euo pipefail

version="${CONTEXT7_MCP_VERSION:-3.0.0}"
kimi_code_home="${KIMI_CODE_HOME:-$HOME/.kimi-code}"
prefix="$kimi_code_home/cache/context7-mcp"
entry="$prefix/node_modules/@upstash/context7-mcp/dist/index.js"
package_json="$prefix/node_modules/@upstash/context7-mcp/package.json"

if ! command -v node >/dev/null 2>&1; then
  echo "context7-mcp: node is required" >&2
  exit 127
fi

needs_install=0
if [[ ! -f "$entry" || ! -f "$package_json" ]]; then
  needs_install=1
elif ! node -e 'const pkg = require(process.argv[1]); process.exit(pkg.version === process.argv[2] ? 0 : 1)' "$package_json" "$version" >/dev/null 2>&1; then
  needs_install=1
fi

if [[ "$needs_install" == 1 ]]; then
  mkdir -p "$prefix"
  npm install --silent --no-audit --no-fund --prefix "$prefix" "@upstash/context7-mcp@$version" >&2
fi

exec node "$entry" "$@"
