#!/usr/bin/env bash
# Manage the stop-hook bypass marker for the current Kimi session or cwd.

set -euo pipefail

base_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$base_dir/hooks/lib/kimi-proof-state.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  skip-stop on
  skip-stop off
  skip-stop status

Set KIMI_SESSION_ID to target a specific session. Without it, the newest
proof directory is never guessed; state is scoped to the current cwd.
EOF
}

cmd="${1:-}"
case "$cmd" in
  on)
    marker=$(kimi_cli_state_file skip-stop skip_stop true) || {
      echo "Invalid KIMI_SESSION_ID; use only letters, digits, '_' or '-'." >&2
      exit 1
    }
    date -u '+created_utc: %Y-%m-%dT%H:%M:%SZ' >"$marker"
    printf 'Stop hook bypass enabled: %s\n' "$marker"
    ;;
  off)
    marker=$(kimi_cli_state_file skip-stop skip_stop false) || {
      echo "Invalid KIMI_SESSION_ID; use only letters, digits, '_' or '-'." >&2
      exit 1
    }
    rm -f "$marker"
    printf 'Stop hook bypass disabled\n'
    ;;
  status)
    marker=$(kimi_cli_state_file skip-stop skip_stop false 2>/dev/null || true)
    if [ -n "${marker:-}" ] && [ -f "$marker" ]; then
      cat "$marker"
    else
      echo "Stop hook bypass inactive"
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac
