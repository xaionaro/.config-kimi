#!/usr/bin/env bash
set -euo pipefail

program=${0##*/}
script_dir=$(cd -P -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -P -- "$script_dir/.." && pwd)
roles_file=$repo_root/lib/codex-roles.txt
session_library=$repo_root/lib/codex-sessions-validate.sh
proof_library=$repo_root/hooks/lib/kimi-proof-state.sh

fail() {
  printf '%s: %s\n' "$program" "$1" >&2
  exit 2
}

[[ -f $roles_file && ! -L $roles_file ]] || fail 'role source is missing or unsafe'
[[ -f $session_library && ! -L $session_library ]] || fail 'session validator is missing or unsafe'
[[ -f $proof_library && ! -L $proof_library ]] || fail 'proof-state library is missing or unsafe'
# shellcheck source=../lib/codex-sessions-validate.sh
. "$session_library"
# shellcheck source=../hooks/lib/kimi-proof-state.sh
. "$proof_library"

roles=()
mapfile -t roles <"$roles_file"
((${#roles[@]} > 0)) || fail 'role source is empty'
role_pattern=
for role in "${roles[@]}"; do
  [[ $role =~ ^[A-Za-z0-9][A-Za-z0-9-]*$ ]] || fail 'role source is invalid'
  role_pattern+=${role_pattern:+|}$role
done

show_help() {
  cat <<'EOF'
Usage:
  codex-issue-marker [--session <id>] --cyber <64-hex-task-sig>
  codex-issue-marker [--session <id>] --orchestration <role>
  codex-issue-marker --help

Issue one fresh, one-use capability marker for codex-first delegation.

Modes:
  --cyber <task-sig>
      Issue a marker named by a 64-character lowercase hexadecimal task_sig.
  --orchestration <role>
      Issue a nonce marker for one approved ECI/ATE role. Allowed roles are
      loaded from ~/.kimi-code/lib/codex-roles.txt:
EOF
  local role
  for role in "${roles[@]}"; do
    printf '        %s\n' "$role"
  done
  cat <<'EOF'

Session selection:
  --session <id> overrides KIMI_SESSION_ID. A session ID may contain only
  ASCII letters, digits, dot, underscore, and hyphen; it must start with a
  letter, digit, or underscore and must not contain two consecutive dots.

The marker path is printed to stdout. Markers are claimed once by
codex-first-gate.sh and expire after 600 seconds. KIMI_PROOF_ROOT replaces the
default ~/.cache/kimi-proof marker root.
EOF
}

sid=${KIMI_SESSION_ID:-}
mode=
value=

while (($#)); do
  case $1 in
    --help)
      show_help
      exit 0
      ;;
    --session)
      (($# >= 2)) || fail '--session requires a value'
      sid=$2
      shift 2
      ;;
    --cyber|--orchestration)
      [[ -z $mode ]] || fail 'choose exactly one marker mode'
      (($# >= 2)) || fail "$1 requires a value"
      mode=$1
      value=$2
      shift 2
      ;;
    *)
      fail "unexpected argument: $1"
      ;;
  esac
done

[[ -n $sid ]] || fail 'KIMI_SESSION_ID or --session is required'
codex_session_id_is_valid "$sid" || fail 'invalid session ID'

case $mode in
  --cyber)
    [[ $value =~ ^[0-9a-f]{64}$ ]] ||
      fail 'task_sig must be 64 lowercase hexadecimal characters'
    name=$value
    ;;
  --orchestration)
    [[ $value =~ ^($role_pattern)$ ]] || fail 'invalid orchestration role'
    nonce=$(od -An -N8 -tx1 /dev/urandom | tr -d ' \n')
    [[ $nonce =~ ^[0-9a-f]{16}$ ]] || fail 'could not generate nonce'
    name=orchestration-$value-$nonce
    ;;
  *)
    fail 'choose --cyber or --orchestration'
    ;;
esac

umask 077
base=$(kimi_proof_root)
session_dir=$base/$sid
dir=$session_dir/cyber-escalation
[[ $base == /* && $base != / ]] || fail 'proof root must be an absolute non-root path'
[[ ! -L $base && ! -L $session_dir && ! -L $dir ]] ||
  fail 'marker directory must not be a symlink'
mkdir -p -- "$dir"
[[ ! -L $base && ! -L $session_dir && ! -L $dir ]] ||
  fail 'marker directory must not be a symlink'
chmod 700 -- "$base" "$session_dir" "$dir"

exec {dfd}<"$dir"
flock -x "$dfd"

tmp=
cleanup() {
  if [[ -n ${tmp:-} && $tmp == "$dir"/.tmp.* ]]; then
    rm -f -- "$tmp"
  fi
}
trap cleanup EXIT

tmp=$(mktemp "$dir/.tmp.XXXXXX")
date +%s >"$tmp"
mv -f -- "$tmp" "$dir/$name"
tmp=

flock -u "$dfd"
printf '%s\n' "$dir/$name"
