#!/usr/bin/env bash
# Manage the ECI active marker for the current Kimi session.

set -euo pipefail

base_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$base_dir/hooks/lib/kimi-proof-state.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  eci-active on "<task + scope>"
  eci-active off <disengage-report.md>
  eci-active status

Set KIMI_SESSION_ID, or KIMI_THREAD_ID when KIMI_SESSION_ID is
unset, to target a session explicitly (unprefixed ids are normalized
to the session_ wire form). Without either, the owning session is
resolved from the kimi ancestor's cwd: sessions whose state.json
workDir matches, freshest wire (<300s) wins; ties and misses refuse
loudly. Cwd-scoped ECI state is never created.
EOF
}

# Test seams (used by the resolver tests in hooks/tests/run.sh; never set
# in production): KIMI_ECI_ACTIVE_TEST_KCWD bypasses the ancestry probe
# with a fixed cwd, and a pre-defined resolve_kimi_ancestor_cwd function
# (export -f a stub) replaces the probe entirely.
if ! declare -F resolve_kimi_ancestor_cwd >/dev/null 2>&1; then
resolve_kimi_ancestor_cwd() {
  local pid=$$ kimi_pid="" _comm _ppid
  while [ "$pid" != "1" ] && [ -n "$pid" ]; do
    read -r _comm _ppid < <(awk '{print $2, $4}' "/proc/$pid/stat" 2>/dev/null) || break
    _comm="${_comm#(}"; _comm="${_comm%)}"
    if [ "$_comm" = "kimi" ]; then kimi_pid="$pid"; break; fi
    pid="$_ppid"
  done
  [ -n "$kimi_pid" ] || return 1
  readlink "/proc/$kimi_pid/cwd" 2>/dev/null
}
fi

resolve_session_dir() {
  root="$(kimi_proof_root)"; sessions_root="${KIMI_CODE_HOME:-$HOME/.kimi-code}/sessions"

  # explicit sid: normalize form + verify, never mint wrong-form dirs
  if [ -n "${KIMI_SESSION_ID:-${KIMI_THREAD_ID:-}}" ]; then
    sid="${KIMI_SESSION_ID:-$KIMI_THREAD_ID}"
    kimi_valid_session_id "$sid" || { echo "Invalid session id: $sid" >&2; exit 1; }
    case "$sid" in session_*) alt="${sid#session_}" ;; *) alt="session_$sid" ;; esac
    if kimi_session_dir_for_id "$sid" >/dev/null 2>&1; then printf '%s/%s\n' "$root" "$sid"; return 0; fi
    if [ -n "$alt" ] && kimi_session_dir_for_id "$alt" >/dev/null 2>&1; then printf '%s/%s\n' "$root" "$alt"; return 0; fi
    if [ -d "$root/$sid" ]; then printf '%s/%s\n' "$root" "$sid"; return 0; fi
    echo "eci-active: no session '$sid' under $sessions_root; known: $(ls "$sessions_root"/*/ -d 2>/dev/null | xargs -n1 basename 2>/dev/null | sort -u | tr '\n' ' ')" >&2; exit 1
  fi

  if [ -n "${KIMI_ECI_ACTIVE_TEST_KCWD:-}" ]; then
    kcwd="$KIMI_ECI_ACTIVE_TEST_KCWD"
  else
    kcwd="$(resolve_kimi_ancestor_cwd)" || { echo "eci-active: no kimi ancestor found; re-run with KIMI_SESSION_ID=session_<uuid>" >&2; exit 1; }
    [ -n "$kcwd" ] || { echo "eci-active: cannot read /proc/$kimi_pid/cwd; re-run with KIMI_SESSION_ID=session_<uuid>" >&2; exit 1; }
  fi

  # candidates: hash bucket, then realpath cross-check, then full state.json scan
  key="$(printf '%s' "$kcwd" | sha256sum | cut -c1-12)"
  kcwd_real="$(realpath "$kcwd")"
  candidates=()
  for sdir in "$sessions_root"/wd_*_"$key"/session_*/ "$sessions_root"/*/session_*/; do
    [ -f "$sdir/state.json" ] || continue
    swd="$(jq -r '.workDir // empty' "$sdir/state.json" 2>/dev/null)"; [ -n "$swd" ] || continue
    [ "$(realpath "$swd" 2>/dev/null)" = "$kcwd_real" ] || continue
    case " ${candidates[*]:-} " in *" ${sdir%/} "*) continue ;; esac
    candidates+=("${sdir%/}")
  done

  fresh=(); now="$(date +%s)"; FRESH=300
  for c in ${candidates[@]+"${candidates[@]}"}; do
    w="$c/agents/main/wire.jsonl"; [ -f "$w" ] || continue
    m="$(stat -c '%Y' "$w" 2>/dev/null)" || continue
    [ $(( now - m )) -lt "$FRESH" ] && fresh+=("$c")
  done

  # freshness floor applies to every bind path
  if [ "${#fresh[@]}" -eq 1 ]; then printf '%s/%s\n' "$root" "${fresh[0]##*/}"; return 0; fi
  echo "eci-active: could not determine owning session for cwd $kcwd (candidates: ${candidates[*]:-none}; fresh<300s: ${fresh[*]:-none}); re-run with KIMI_SESSION_ID=session_<uuid>" >&2; exit 1
}

validate_disengage_report() {
  local report="$1"
  local missing=""
  local marker_error=""
  local section

  for section in "Stop checklist walkthrough" "Incomplete compliance"; do
    if ! kimi_markdown_section_has_body "$report" "$section"; then
      missing="$missing \"$section\""
    fi
  done

  if [ -n "$missing" ]; then
    echo "Disengage report missing non-empty ECI section(s):$missing" >&2
    return 1
  fi

  marker_error="$(kimi_eci_terminal_verdict_error "Disengage report" "$report")"
  if [ -n "$marker_error" ]; then
    echo "$marker_error" >&2
    return 1
  fi

  if kimi_markdown_section_has_body "$report" "ECI completion certificate"; then
    return 0
  fi

  local full_missing=""
  for section in \
    "Summary" \
    "Verification" \
    "Requirements" \
    "Root Cause" \
    "Claim Inventory" \
    "Pre-Mortem" \
    "Adversarial Critique" \
    "Rule-Compliance Self-Audit" \
    "Gaps"; do
    if ! kimi_markdown_section_has_body "$report" "$section"; then
      full_missing="$full_missing \"$section\""
    fi
  done

  if [ -n "$full_missing" ]; then
    echo "Disengage report must include either a non-empty \"ECI completion certificate\" section or all full Kimi stop-verification sections." >&2
    echo "Missing full stop-verification section(s):$full_missing" >&2
    return 1
  fi
}

remove_legacy_eci_markers_for_cwd() {
  local keep="${1:-}"
  local marker

  while IFS= read -r marker; do
    [ -n "$marker" ] || continue
    [ -n "$keep" ] && [ "$marker" = "$keep" ] && continue
    rm -f "$marker"
  done < <(kimi_legacy_eci_markers_for_cwd "$PWD" 2>/dev/null || true)
}

cmd="${1:-}"
case "$cmd" in
  on)
    shift
    scope="${*:-}"
    [ -n "$scope" ] || { usage; exit 2; }
    session_dir="$(resolve_session_dir)" || {
      echo "eci-active: no session directory found under $(kimi_proof_root)" >&2
      exit 1
    }
    marker="$session_dir/eci_active"
    mkdir -p "$session_dir"
    {
      printf 'scope: %s\n' "$scope"
      printf 'cwd: %s\n' "$PWD"
      printf 'session_id: %s\n' "${session_dir##*/}"
      date -u '+created_utc: %Y-%m-%dT%H:%M:%SZ'
    } >"$marker"
    remove_legacy_eci_markers_for_cwd "$marker"
    printf 'ECI active: %s\n' "$marker"
    ;;
  off)
    report="${2:-}"
    markers=()
    [ -n "$report" ] || { usage; exit 2; }
    [ -f "$report" ] || { echo "Disengage report not found: $report" >&2; exit 1; }
    session_dir="$(resolve_session_dir)" || {
      echo "eci-active: no session directory found under $(kimi_proof_root)" >&2
      exit 1
    }
    marker="$session_dir/eci_active"
    [ -f "$marker" ] && markers+=("$marker")
    while IFS= read -r legacy_marker; do
      [ -n "$legacy_marker" ] || continue
      [ "$legacy_marker" = "$marker" ] && continue
      markers+=("$legacy_marker")
    done < <(kimi_legacy_eci_markers_for_cwd "$PWD" 2>/dev/null || true)
    [ "${#markers[@]}" -gt 0 ] || { echo "ECI marker is not active: $marker" >&2; exit 1; }
    validate_disengage_report "$report"
    rm -f "${markers[@]}"
    printf 'ECI inactive. Disengage report validated: %s\n' "$report"
    ;;
  status)
    session_dir="$(resolve_session_dir)" || {
      echo "eci-active: no session directory found under $(kimi_proof_root)" >&2
      exit 1
    }
    marker="$session_dir/eci_active"
    if [ -n "${marker:-}" ] && [ -f "$marker" ]; then
      cat "$marker"
    elif legacy_marker="$(kimi_legacy_eci_markers_for_cwd "$PWD" 2>/dev/null | head -n1)" &&
      [ -n "$legacy_marker" ] && [ -f "$legacy_marker" ]; then
      cat "$legacy_marker"
    else
      echo "ECI inactive"
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac
