#!/usr/bin/env bash
set -euo pipefail

fail() {
  printf '%s\n' "bootstrap-config: $1" >&2
  exit 1
}

show_help() {
  cat <<'EOF'
Usage:
  bootstrap-config
  bootstrap-config --help

Materialize config.example.toml as a private config.toml when none exists.
For an existing safe regular config, append the codex-first Agent/AgentSwarm
hook exactly once without replacing existing bytes. KIMI_CODE_HOME selects the
data root; otherwise the default is ~/.kimi-code.
EOF
}

case $# in
  0) ;;
  1)
    [[ $1 == --help ]] || fail "unexpected argument: $1"
    show_help
    exit 0
    ;;
  *) fail 'expected no arguments or --help' ;;
esac

if [[ -n ${KIMI_CODE_HOME:-} ]]; then
  data_root=$KIMI_CODE_HOME
elif [[ -n ${HOME:-} ]]; then
  data_root=$HOME/.kimi-code
else
  fail 'KIMI_CODE_HOME or HOME is required'
fi

case $data_root in
  /*) ;;
  *) fail 'data root must be absolute' ;;
esac
while :; do
  case $data_root in
    /|/.) data_root=/; break ;;
    */.) data_root=${data_root%/.} ;;
    */) data_root=${data_root%/} ;;
    *) break ;;
  esac
done
[[ $data_root != / ]] || fail 'filesystem root is not a data root'
root_parent=$(dirname -- "$data_root") || fail 'cannot split data root'
root_name=$(basename -- "$data_root") || fail 'cannot split data root'
case $root_name in
  .|..) fail 'data root must not end in . or ..' ;;
esac
physical_parent=$(cd -P -- "$root_parent" && pwd) ||
  fail 'data root parent is inaccessible'
case $physical_parent in
  /) physical_root=/$root_name ;;
  *) physical_root=$physical_parent/$root_name ;;
esac
[[ $physical_root != / ]] || fail 'filesystem root is not a data root'
[[ ! -L $physical_root ]] || fail 'data root must not be a symlink'
[[ -d $physical_root ]] || fail 'data root must be an existing directory'
root_owner=$(stat -c %u -- "$physical_root") || fail 'cannot inspect data root'
[[ $root_owner == "$(id -u)" ]] ||
  fail 'data root must be owned by the current user'

script_dir=$(cd -P -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd) ||
  fail 'script directory is inaccessible'
template=$script_dir/../config.example.toml
hook_normalizer=$script_dir/bootstrap-config-hooks
[[ -f $template && ! -L $template ]] || fail 'config example is missing or unsafe'
[[ -f $hook_normalizer && ! -L $hook_normalizer ]] ||
  fail 'hook normalizer is missing or unsafe'
python3 "$hook_normalizer" validate-template "$template" ||
  fail 'config example must contain exactly one correct codex-first gate hook'

chmod 0700 -- "$physical_root" || fail 'cannot protect data root'
[[ ! -L $physical_root && -d $physical_root ]] ||
  fail 'data root changed during validation'
root_mode=$(stat -c %a -- "$physical_root") || fail 'cannot inspect data root mode'
[[ $root_mode == 700 ]] || fail 'data root mode is not private'

target=$physical_root/config.toml

protect_existing_target() {
  [[ ! -L $target ]] || return 1
  [[ -f $target ]] || return 1
  [[ $(stat -c %u -- "$target") == "$(id -u)" ]] || return 1
  chmod 0600 -- "$target" || return 1
  [[ ! -L $target && -f $target && $(stat -c %a -- "$target") == 600 ]]
}

temporary=
cleanup() {
  if [[ -n $temporary && -f $temporary && ! -L $temporary ]]; then
    rm -f -- "$temporary"
  fi
}
trap cleanup EXIT HUP INT TERM

prepare_temporary() {
  temporary=$(mktemp "$physical_root/.config.toml.tmp.XXXXXX") ||
    fail 'cannot prepare config temporary file'
  chmod 0600 -- "$temporary" || fail 'cannot protect config temporary file'
}

inject_existing_hook() {
  protect_existing_target || fail 'config target must be a safe regular file'
  prepare_temporary
  python3 "$hook_normalizer" normalize "$target" "$template" "$temporary" ||
    fail 'cannot structurally normalize gate hook stanzas'
  chmod 0600 -- "$temporary" || fail 'cannot protect prepared config'
  protect_existing_target || fail 'config target changed during update'
  if cmp -s -- "$target" "$temporary"; then
    rm -- "$temporary"
    temporary=
    return
  fi
  mv -f -- "$temporary" "$target" || fail 'cannot publish updated config'
  temporary=
  protect_existing_target || fail 'published config is not a safe regular file'
}

if [[ -L $target ]]; then
  fail 'config target must not be a symlink'
fi
if [[ -e $target ]]; then
  inject_existing_hook
  exit 0
fi

prepare_temporary
cp -- "$template" "$temporary" || fail 'cannot prepare config bytes'
chmod 0600 -- "$temporary" || fail 'cannot protect config temporary file'

if ln -T -- "$temporary" "$target" 2>/dev/null; then
  rm -- "$temporary"
  temporary=
elif protect_existing_target; then
  rm -- "$temporary"
  temporary=
  inject_existing_hook
else
  fail 'config target appeared in an unsafe form'
fi

protect_existing_target || fail 'published config is not a safe regular file'
